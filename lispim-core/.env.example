# LispIM 开发环境配置
# 复制此文件为 .env 并修改相应值

# ===========================================
# 服务器配置
# ===========================================
LISPIM_HOST=0.0.0.0
LISPIM_PORT=4321
LOG_LEVEL=debug

# ===========================================
# 数据库配置 (Docker)
# ===========================================
DATABASE_URL=postgresql://lispim:Clsper03@localhost:5432/lispim
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=lispim
DATABASE_USER=lispim
DATABASE_PASSWORD=Clsper03

# ===========================================
# Redis 配置 (Docker)
# ===========================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ===========================================
# MinIO 对象存储配置 (Docker)
# ===========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=lispim
MINIO_SECRET_KEY=Clsper03
MINIO_BUCKET=lispim-files
MINIO_USE_SSL=false

# ===========================================
# 邮件配置（开发环境使用 MailHog）
# ===========================================
# MailHog SMTP 配置
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@lispim.local

# 生产环境配置示例（QQ 邮箱）
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your-qq-email@qq.com
# SMTP_PASSWORD=your-auth-code  # 授权码，不是登录密码
# SMTP_FROM=your-qq-email@qq.com

# ===========================================
# 短信配置（开发环境打印到日志）
# ===========================================
SMS_PROVIDER=none
# 生产环境配置示例
# SMS_PROVIDER=aliyun
# SMS_ALIYUN_ACCESS_KEY=your-access-key
# SMS_ALIYUN_ACCESS_SECRET=your-access-secret
# SMS_ALIYUN_SIGN_NAME=你的签名
# SMS_ALIYUN_TEMPLATE_CODE=SMS_123456789

# ===========================================
# OpenClaw AI 配置（可选）
# ===========================================
OPENCLAW_ENDPOINT=
OPENCLAW_API_KEY=

# ===========================================
# JWT 配置
# ===========================================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=86400

# ===========================================
# 文件上传配置
# ===========================================
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=./uploads

# ===========================================
# Docker 服务访问 URL
# ===========================================
MAILHOG_UI_URL=http://localhost:8025
MINIO_CONSOLE_URL=http://localhost:9001
ADMINER_URL=http://localhost:8080
REDIS_COMMANDER_URL=http://localhost:8081
